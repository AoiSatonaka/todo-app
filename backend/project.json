{
  "name": "backend",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "./backend",
  "targets": {
    "protoc": {
      "command": "docker compose run --rm -u $(id -u $USER) protoc-go sh ./docker/protoc/go/protoc.sh"
    },
    "build": {
      "executor": "@nx-go/nx-go:build",
      "dependsOn": ["protoc"],
      "options": {
        "outputPath": "dist/backend",
        "main": "backend/main.go"
      }
    },
    "serve": {
      "command": "docker compose --profile backend up -d"
    },
    "test": {
      "executor": "@nx-go/nx-go:test"
    },
    "lint": {
      "executor": "@nx-go/nx-go:lint"
    }
  },
  "tags": []
}
